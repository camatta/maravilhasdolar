{
  "flex-layout.col#product-resume": {
    "title": "Informações do produto",
    "props": {
      "blockClass": "product-resume-content",
      "preventVerticalStretch": true,
      "width": "100%"
    },
    "children": [
      "responsive-layout.desktop#resume-pdp",
      "responsive-layout.mobile#resume-pdp"
    ]
  },

  "responsive-layout.desktop#resume-pdp": {
    "children": [
      "remove-video",
      "flex-layout.row#name-wish",
      "flex-layout.row#product-meta",
      "flex-layout.row#prices-pdp",
      "flex-layout.row#leve-mais-pdp",
      "flex-layout.row#sku-selector",
      "flex-layout.row#actions-pdp",
      "flex-layout.row#shipping",
      "flex-layout.row#product-warning-b2b"
    ]
  },

  "responsive-layout.mobile#resume-pdp": {
    "children": [
      "flex-layout.row#name-wish",
      "flex-layout.row#product-meta",
      "flex-layout.row#prices-pdp",
      "flex-layout.row#leve-mais-pdp",
      "flex-layout.row#sku-selector",
      "flex-layout.row#actions-pdp",
      "flex-layout.row#shipping",
      "flex-layout.row#product-warning-b2b"
    ]
  }
}
